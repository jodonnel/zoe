FROM registry.access.redhat.com/ubi9/python-312:latest

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY server.py .

# State dir mounted at runtime
VOLUME /state

ENV ZOE_ROOT=/state
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

USER 1001

CMD ["python", "server.py"]
